# ============================================================
# PRODUCTION ENVIRONMENT CONFIGURATION
# For Railway Deployment
# ============================================================

# ──────────────────────────────────────
# SERVER CONFIG
# ──────────────────────────────────────
HOST=0.0.0.0
# PORT is auto-provided by Railway
ENVIRONMENT=production
DEBUG=false

# ──────────────────────────────────────
# APP INFO
# ──────────────────────────────────────
APP_NAME=Chatbot Tài Xế Xanh SM
APP_VERSION=1.0.0

# ──────────────────────────────────────
# AI & LLM CONFIG
# ──────────────────────────────────────
OPENAI_API_KEY=sk-proj-YOUR-REAL-KEY-HERE
LLM_MODEL=gpt-4o-mini
AI_TEMPERATURE=0.0
MAX_TOKENS=500

# ──────────────────────────────────────
# RAG & RETRIEVAL CONFIG
# ──────────────────────────────────────
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
RETRIEVAL_TOP_K=5
RERANK_TOP_K=5

# ──────────────────────────────────────
# SECURITY CONFIG
# ──────────────────────────────────────
# CRITICAL: Generate secure random string for production
# Example: openssl rand -hex 32
AGENT_API_KEY=CHANGE-THIS-TO-SECURE-RANDOM-STRING

# CORS: Specify exact origins in production (không dùng *)
# Example: https://your-frontend.com,https://app.example.com
ALLOWED_ORIGINS=*

# ──────────────────────────────────────
# REDIS CONFIG
# ──────────────────────────────────────
# Railway auto-provides REDIS_URL when you add Redis service
# REDIS_URL=redis://...  (Railway injects this)
REDIS_ENABLED=true

# ──────────────────────────────────────
# RATE LIMITING CONFIG
# ──────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=10

# ──────────────────────────────────────
# COST GUARD CONFIG
# ──────────────────────────────────────
COST_GUARD_ENABLED=true
MONTHLY_BUDGET_USD=10.0

# ──────────────────────────────────────
# LOGGING CONFIG
# ──────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json

# ──────────────────────────────────────
# NOTES
# ──────────────────────────────────────
# 1. Copy this file content to Railway environment variables
# 2. DO NOT commit .env.production with real secrets to Git
# 3. Generate secure AGENT_API_KEY: openssl rand -hex 32
# 4. Railway auto-provides: PORT, REDIS_URL (if Redis addon added)
