# ============================================================
# RAILWAY Dockerfile — Build from repo root
# ============================================================

FROM python:3.11-slim AS builder

WORKDIR /build

RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    g++ \
    libgomp1 \
    && rm -rf /var/lib/apt/lists/*

# Copy requirements from backend_ai directory
COPY backend_ai/requirements.txt .
RUN pip install --no-cache-dir --user -r requirements.txt

RUN python -c "import fastapi; import langchain; import faiss; import sentence_transformers; print('✅ All packages installed')"

# ──────────────────────────────────────────────────────────
# STAGE 2: Runtime
# ──────────────────────────────────────────────────────────
FROM python:3.11-slim AS runtime

RUN apt-get update && apt-get install -y --no-install-recommends \
    libgomp1 \
    curl \
    && rm -rf /var/lib/apt/lists/*

RUN groupadd -r appuser && useradd -r -g appuser -u 1000 appuser

WORKDIR /app

COPY --from=builder /root/.local /home/appuser/.local

# Copy application code from backend_ai directory
COPY backend_ai/app/ /app/app/

# Copy startup script
COPY backend_ai/start.sh /app/start.sh

# Copy knowledge base from data_pipeline
COPY data_pipeline/db_setup /app/data_pipeline/db_setup

RUN mkdir -p /app/data_pipeline/db_setup && \
    chmod +x /app/start.sh && \
    chown -R appuser:appuser /app

USER appuser

ENV PATH=/home/appuser/.local/bin:$PATH
ENV PYTHONPATH=/app
ENV HOST=0.0.0.0
ENV PORT=8000
ENV ENVIRONMENT=production
ENV LOG_FORMAT=json

EXPOSE 8000

HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:8000/health').read()" || exit 1

# Use startup script to handle PORT variable expansion
CMD ["/app/start.sh"]
