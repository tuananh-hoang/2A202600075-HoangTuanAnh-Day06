# ============================================================
# ENVIRONMENT CONFIGURATION TEMPLATE
# Copy this file to .env and fill in your values
# ============================================================

# ──────────────────────────────────────
# SERVER CONFIG
# ──────────────────────────────────────
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development  # development | staging | production
DEBUG=false

# ──────────────────────────────────────
# APP INFO
# ──────────────────────────────────────
APP_NAME=Chatbot Tài Xế Xanh SM
APP_VERSION=1.0.0

# ──────────────────────────────────────
# AI & LLM CONFIG
# ──────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
LLM_MODEL=gpt-4o-mini
AI_TEMPERATURE=0.0
MAX_TOKENS=500

# ──────────────────────────────────────
# RAG & RETRIEVAL CONFIG
# ──────────────────────────────────────
# Paths are auto-detected, override only if needed
# SQLITE_PATH=data_pipeline/db_setup/knowledge_base.sqlite
# FAISS_PATH=data_pipeline/db_setup/knowledge_base.faiss
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
RETRIEVAL_TOP_K=5
RERANK_TOP_K=5

# ──────────────────────────────────────
# SECURITY CONFIG
# ──────────────────────────────────────
# API key for authentication (required in production)
AGENT_API_KEY=your_secret_api_key_here

# CORS allowed origins (comma-separated, or * for all)
ALLOWED_ORIGINS=*

# ──────────────────────────────────────
# REDIS CONFIG (for rate limiting & stateless)
# ──────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=false

# ──────────────────────────────────────
# RATE LIMITING CONFIG
# ──────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=10

# ──────────────────────────────────────
# COST GUARD CONFIG
# ──────────────────────────────────────
COST_GUARD_ENABLED=true
MONTHLY_BUDGET_USD=10.0

# ──────────────────────────────────────
# LOGGING CONFIG
# ──────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json  # json | text

# ──────────────────────────────────────
# FRONTEND CONFIG (for Streamlit)
# ──────────────────────────────────────
BACKEND_URL=http://localhost:8000/chat
